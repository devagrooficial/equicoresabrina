---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/dashboard/Header';
import { EquineProfile } from '../../../components/dashboard/EquineProfile';
import { createServerSupabaseClient } from '../../../lib/supabase';

const { id } = Astro.params;
const responseHeaders = new Headers();
const supabase = createServerSupabaseClient(Astro.request, responseHeaders);

const { data: row, error } = await supabase
  .from('equinos')
  .select('*')
  .eq('id', id)
  .single();

if (error || !row) {
  return Astro.redirect('/dashboard/plantel');
}

function calcAge(birthDate: string | null, estimatedAge: number | null): string {
  if (birthDate) {
    const months = Math.floor((Date.now() - new Date(birthDate).getTime()) / (1000 * 60 * 60 * 24 * 30.44));
    if (months < 24) return `${months} meses`;
    return `${Math.floor(months / 12)} anos`;
  }
  if (estimatedAge) return estimatedAge < 24 ? `${estimatedAge} meses` : `${Math.floor(estimatedAge / 12)} anos`;
  return '—';
}

const reg = [row.reg_abqm, row.reg_abccm, row.reg_abpsi, row.reg_abccc, row.reg_other].find(Boolean) ?? '';

const equineData = {
  id: row.id,
  name: row.name,
  nickname: row.nickname,
  breed: row.breed,
  sex: row.sex,
  coat: row.coat,
  age: calcAge(row.birth_date, row.estimated_age),
  registration: reg,
  healthStatus: row.health_status ?? 'healthy',
  feedKgDay: row.feed_kg_day,
  feedBrand: row.feed_brand,
  hayKgDay: row.hay_kg_day,
  hayType: row.hay_type,
  waterAccess: row.water_access,
  supplements: row.supplements,
  weightKg: row.weight_kg,
  heightCm: row.height_cm,
  bcs: row.bcs,
  fatherName: row.father_name,
  fatherReg: row.father_reg,
  motherName: row.mother_name,
  motherReg: row.mother_reg,
  patGrandfather: row.pat_grandfather,
  patGrandmother: row.pat_grandmother,
  matGrandfather: row.mat_grandfather,
  matGrandmother: row.mat_grandmother,
};
---

<Layout title={`${row.name} — EquiCore`}>
  <Header client:load currentPath={Astro.url.pathname} />
  <main class="w-full max-w-5xl mx-auto px-4 md:px-8 py-8">
    <EquineProfile client:load equine={equineData} />
  </main>
</Layout>
