---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/dashboard/Header.tsx';
import { CriticalAlerts } from '../../components/dashboard/CriticalAlerts.tsx';
import type { Alert } from '../../components/dashboard/CriticalAlerts.tsx';
import { EquineCard } from '../../components/dashboard/EquineCard.tsx';
import type { Equine } from '../../components/dashboard/EquineCard.tsx';
import { createServerSupabaseClient } from '../../lib/supabase';
import { calculateAlertStatus } from '../../lib/alertStatus';

const responseHeaders = new Headers();
const supabase = createServerSupabaseClient(Astro.request, responseHeaders);

// ─── Dados reais ──────────────────────────────────────────────────────────────
const { data: equinosRaw } = await supabase
  .from('equinos')
  .select('id, name, nickname, breed, birth_date, estimated_age')
  .order('created_at', { ascending: false });

const { data: alertRaw } = await supabase
  .from('equine_alerts')
  .select('id, equine_id, due_date, status_override, resolved_at, template:alert_templates(name, category, periodicity_months)');

const equinos = equinosRaw ?? [];
const alertRows = alertRaw ?? [];

const BREED_LABEL: Record<string, string> = {
  QUARTO_DE_MILHA: 'Quarto de Milha', MANGALARGA_MARCHADOR: 'Mangalarga Marchador',
  PURO_SANGUE_INGLES: 'Puro Sangue Inglês', LUSITANO: 'Lusitano',
  BRASILEIRO_DE_HIPISMO: 'Brasileiro de Hipismo', CRIOULO: 'Crioulo',
  CAMPOLINA: 'Campolina', APPALOOSA: 'Appaloosa', PAINT_HORSE: 'Paint Horse',
  ANDALUZ: 'Andaluz', ARABE: 'Árabe', HAFLINGER: 'Haflinger',
  FRIESIO: 'Frísio', ARDENÊS: 'Ardenês', OTHER: 'Outra raça',
};

function calcAge(birthDate: string | null, estimatedAge: number | null): string {
  if (birthDate) {
    const months = Math.floor((Date.now() - new Date(birthDate).getTime()) / (1000 * 60 * 60 * 24 * 30.44));
    return months < 24 ? `${months} meses` : `${Math.floor(months / 12)} anos`;
  }
  if (estimatedAge) return estimatedAge < 24 ? `${estimatedAge} meses` : `${Math.floor(estimatedAge / 12)} anos`;
  return '—';
}

const RANK: Record<string, number> = { VENCIDA: 5, CRITICO: 4, URGENTE: 3, ATENCAO: 2 };

function alertRank(a: any): number {
  if (a.status_override === 'NAO_POSSUI') return -1;
  const permanent = a.template?.periodicity_months == null;
  if (permanent) return a.resolved_at ? 0 : 1;      // possui = em dia ; senão pendente
  if (!a.due_date) return 1;                          // pendente sem data
  const k = calculateAlertStatus(a.due_date).key;
  if (k === 'PENDENTE') return 0;                     // data folgada = em dia
  return RANK[k] ?? 0;
}

function alertDays(a: any): number | null {
  const permanent = a.template?.periodicity_months == null;
  if (permanent || !a.due_date) return null;
  return calculateAlertStatus(a.due_date).daysRemaining;
}

const equineNameById = new Map(equinos.map((e: any) => [e.id, e.nickname || e.name]));

// Pior rank por equino
const worstByEquine = new Map<string, number>();
for (const e of equinos) worstByEquine.set(e.id, 0);
for (const a of alertRows) {
  const r = alertRank(a);
  const cur = worstByEquine.get(a.equine_id) ?? 0;
  if (r > cur) worstByEquine.set(a.equine_id, r);
}

// KPIs
let kpiEmDia = 0, kpiAtencao = 0, kpiCritico = 0;
for (const e of equinos) {
  const w = worstByEquine.get(e.id) ?? 0;
  if (w >= 4) kpiCritico++;
  else if (w >= 1) kpiAtencao++;
  else kpiEmDia++;
}

// Status do card por equino
function cardStatus(w: number): Equine['status'] {
  if (w >= 4) return 'critical';
  if (w >= 2) return 'vaccine_due';
  if (w >= 1) return 'doc_pending';
  return 'healthy';
}

const equineCards: Equine[] = equinos.map((e: any) => ({
  id: e.id,
  name: e.nickname || e.name,
  breed: BREED_LABEL[e.breed] ?? e.breed,
  age: 0,
  ageText: calcAge(e.birth_date, e.estimated_age),
  status: cardStatus(worstByEquine.get(e.id) ?? 0),
  initials: (e.nickname || e.name).split(' ').slice(0, 2).map((w: string) => w[0]).join('').toUpperCase(),
}));

// Alertas ativos (rank >= 1) ordenados por urgência
const activeAlerts = alertRows
  .map((a: any) => ({ a, rank: alertRank(a), days: alertDays(a) }))
  .filter((x) => x.rank >= 1)
  .sort((x, y) => (y.rank - x.rank) || ((x.days ?? 9999) - (y.days ?? 9999)));

const sidebarAlerts: Alert[] = activeAlerts.slice(0, 6).map(({ a, days }) => ({
  id: a.id,
  type: a.template?.category === 'Documento' ? 'exam' : 'vaccine',
  horse: equineNameById.get(a.equine_id) ?? 'Equino',
  description: a.template?.name ?? 'Item',
  daysLeft: days,
  equineId: a.equine_id,
}));

// Subtítulo do card Crítico
const topCritical = activeAlerts.find((x) => x.rank >= 4);
let criticoSubtitle = 'Nenhum item crítico';
if (topCritical) {
  const nome = topCritical.a.template?.name ?? 'Item';
  const d = topCritical.days;
  criticoSubtitle = d == null ? `${nome} pendente`
    : d < 0 ? `${nome} vencido há ${Math.abs(d)} dia${Math.abs(d) !== 1 ? 's' : ''}`
    : `${nome} vence em ${d} dia${d !== 1 ? 's' : ''}`;
}
const atencaoSubtitle = kpiAtencao > 0 ? 'Requer ação nos próximos dias' : 'Nenhum item em atenção';
---

<Layout title="Dashboard — Equicore" description="Painel de controle Equicore">
  <!-- Header -->
  <Header client:load currentPath={Astro.url.pathname} />

  <!-- Main content -->
  <main class="w-full max-w-7xl mx-auto px-4 md:px-8 py-8 space-y-8">

    <!-- ── Seção 1: Resumo do Plantel (KPIs) ──────────────────────────────── -->
    <section>
      <div class="flex items-center justify-between mb-5">
        <div>
          <h1 class="text-xl font-bold tracking-tight text-foreground">
            Resumo do Plantel
          </h1>
          <p class="text-sm text-muted-foreground mt-0.5">
            Visão geral dos seus equinos
          </p>
        </div>
        <!-- Date stamp -->
        <span class="hidden sm:block text-xs text-muted-foreground bg-muted px-3 py-1.5 rounded-lg font-medium">
          {new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long' })}
        </span>
      </div>

      <!-- KPI Cards grid: 2x2 mobile, 4 colunas desktop -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">

        <!-- KPI: Total de Equinos -->
        <div class="rounded-2xl border bg-card p-3 md:p-5 flex flex-col gap-2 md:gap-3 transition-all duration-200 hover:shadow-md hover:-translate-y-px"
             style="border-color: hsl(var(--border));">
          <div class="flex items-center justify-between">
            <span class="text-[10px] md:text-xs font-semibold tracking-widest uppercase leading-tight"
                  style="color: hsl(var(--muted-foreground));">
              Total de Equinos
            </span>
            <div class="w-7 h-7 md:w-8 md:h-8 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: hsl(168 83% 29% / 0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(168, 83%, 29%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2C11 2 10 3 10 5v2H7L5 9v2l2 1v4l-2 2v2h4v-2l2-1 2 1v2h4v-2l-2-2v-4l2-1V9l-2-2h-3V5c0-2-1-3-1-3z"/>
              </svg>
            </div>
          </div>
          <div class="flex items-end gap-1.5">
            <span class="text-3xl md:text-4xl font-black tracking-tight" style="color: hsl(var(--foreground));">{equinos.length}</span>
            <span class="text-xs md:text-sm pb-0.5" style="color: hsl(var(--muted-foreground));">equinos</span>
          </div>
          <p class="text-[11px] md:text-xs" style="color: hsl(var(--muted-foreground));">Cadastrados no sistema</p>
        </div>

        <!-- KPI: Saúde em Dia -->
        <div class="rounded-2xl border bg-card p-3 md:p-5 flex flex-col gap-2 md:gap-3 transition-all duration-200 hover:shadow-md hover:-translate-y-px"
             style="border-color: hsl(142 71% 45% / 0.3); background: hsl(142 71% 45% / 0.04);">
          <div class="flex items-center justify-between">
            <span class="text-[10px] md:text-xs font-semibold tracking-widest uppercase leading-tight"
                  style="color: hsl(142 71% 35%);">
              Saúde em Dia
            </span>
            <div class="w-7 h-7 md:w-8 md:h-8 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: hsl(142 71% 45% / 0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(142, 71%, 35%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
          </div>
          <div class="flex items-end gap-1.5">
            <span class="text-3xl md:text-4xl font-black tracking-tight" style="color: hsl(142 71% 35%);">{kpiEmDia}</span>
            <span class="text-xs md:text-sm pb-0.5 flex items-center gap-0.5" style="color: hsl(142 71% 35%);">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
              em ordem
            </span>
          </div>
          <p class="text-[11px] md:text-xs" style="color: hsl(142 71% 40%);">Documentação e vacinas OK</p>
        </div>

        <!-- KPI: Atenção -->
        <div class="rounded-2xl border bg-card p-3 md:p-5 flex flex-col gap-2 md:gap-3 transition-all duration-200 hover:shadow-md hover:-translate-y-px"
             style="border-color: hsl(38 92% 50% / 0.3); background: hsl(38 92% 50% / 0.04);">
          <div class="flex items-center justify-between">
            <span class="text-[10px] md:text-xs font-semibold tracking-widest uppercase leading-tight"
                  style="color: hsl(38 92% 30%);">
              Atenção
            </span>
            <div class="w-7 h-7 md:w-8 md:h-8 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: hsl(38 92% 50% / 0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(38, 92%, 30%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                <path d="M12 9v4"/><path d="M12 17h.01"/>
              </svg>
            </div>
          </div>
          <div class="flex items-end gap-1.5">
            <span class="text-3xl md:text-4xl font-black tracking-tight" style="color: hsl(38 92% 30%);">{kpiAtencao}</span>
            <span class="text-xs md:text-sm pb-0.5" style="color: hsl(38 92% 35%);">{kpiAtencao === 1 ? 'item' : 'itens'}</span>
          </div>
          <p class="text-[11px] md:text-xs" style="color: hsl(38 92% 35%);">{atencaoSubtitle}</p>
        </div>

        <!-- KPI: Crítico -->
        <div class="rounded-2xl border bg-card p-3 md:p-5 flex flex-col gap-2 md:gap-3 transition-all duration-200 hover:shadow-md hover:-translate-y-px"
             style="border-color: hsl(0 84.2% 60.2% / 0.3); background: hsl(0 84.2% 60.2% / 0.04);">
          <div class="flex items-center justify-between">
            <span class="text-[10px] md:text-xs font-semibold tracking-widest uppercase leading-tight"
                  style="color: hsl(0 84.2% 40%);">
              Crítico
            </span>
            <div class="w-7 h-7 md:w-8 md:h-8 rounded-xl flex items-center justify-center flex-shrink-0"
                 style="background: hsl(0 84.2% 60.2% / 0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="hsl(0, 84.2%, 40%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" x2="12" y1="8" y2="12"/>
                <line x1="12" x2="12.01" y1="16" y2="16"/>
              </svg>
            </div>
          </div>
          <div class="flex items-end gap-1.5">
            <span class="text-3xl md:text-4xl font-black tracking-tight" style="color: hsl(0 84.2% 40%);">{kpiCritico}</span>
            <span class="text-xs md:text-sm pb-0.5" style="color: hsl(0 84.2% 45%);">{kpiCritico === 1 ? 'requer ação' : 'requerem ação'}</span>
          </div>
          <p class="text-[11px] md:text-xs" style="color: hsl(0 84.2% 45%);">{criticoSubtitle}</p>
        </div>

      </div>
    </section>

    <!-- ── Seção 2: Área Operacional — Grid 12 colunas ────────────────────── -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-8 w-full items-start">

      <!-- Coluna Esquerda: Alertas Críticos (4 cols) -->
      <div class="lg:col-span-4 h-full">
        <CriticalAlerts client:load alerts={sidebarAlerts} total={activeAlerts.length} />
      </div>

      <!-- Coluna Direita: Plantel (8 cols) -->
      <div class="lg:col-span-8 flex flex-col gap-4">

        <!-- Panel header -->
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-base font-bold tracking-tight text-foreground">
              Plantel
            </h2>
            <p class="text-xs mt-0.5" style="color: hsl(var(--muted-foreground));">
              {equinos.length} {equinos.length === 1 ? 'equino cadastrado' : 'equinos cadastrados'}
            </p>
          </div>
          <a
            href="/dashboard/plantel"
            class="text-xs font-semibold px-3 py-1.5 rounded-lg transition-all duration-200 hover:bg-muted"
            style="color: hsl(168 83% 29%);"
          >
            Gerenciar →
          </a>
        </div>

        <!-- Search -->
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none"
               style="color: hsl(var(--muted-foreground));">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
          </div>
          <input
            type="search"
            id="equine-search"
            placeholder="Filtrar por nome ou raça..."
            class="w-full pl-9 pr-4 py-2.5 text-sm rounded-xl border transition-all duration-200 outline-none focus:ring-2"
            style="
              background: hsl(var(--background));
              border-color: hsl(var(--border));
              color: hsl(var(--foreground));
              --tw-ring-color: hsl(168 83% 29% / 0.3);
            "
          />
        </div>

        <!-- EquineCards list -->
        <div class="flex flex-col gap-3" id="equine-list">
          {equineCards.length === 0 ? (
            <div class="text-center py-10" style="color: hsl(var(--muted-foreground));">
              <p class="text-2xl mb-2">🐴</p>
              <p class="text-sm font-semibold" style="color: hsl(var(--foreground));">Nenhum equino cadastrado</p>
              <a href="/dashboard/plantel/novo" class="text-sm font-semibold" style="color: hsl(168 83% 29%);">Cadastrar primeiro equino →</a>
            </div>
          ) : equineCards.map((equine) => (
            <EquineCard equine={equine} client:load />
          ))}
        </div>

      </div>
    </section>

  </main>
</Layout>

<!-- Client-side search filter -->
<script>
  const input = document.getElementById('equine-search') as HTMLInputElement | null;
  const list = document.getElementById('equine-list');

  if (input && list) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      const cards = list.querySelectorAll('a');
      cards.forEach((card) => {
        const text = card.textContent?.toLowerCase() ?? '';
        (card as HTMLElement).style.display = !q || text.includes(q) ? '' : 'none';
      });
    });
  }
</script>

<style>
  /* Utility aliases consumed via inline style vars */
  .text-foreground { color: hsl(var(--foreground)); }
  .text-muted-foreground { color: hsl(var(--muted-foreground)); }
  .bg-card { background-color: hsl(var(--card)); }
  .bg-muted { background-color: hsl(var(--muted)); }
  input::placeholder { color: hsl(var(--muted-foreground)); }
</style>
