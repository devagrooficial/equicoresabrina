---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/dashboard/Header';
import { createServerSupabaseClient } from '../../../lib/supabase';

const responseHeaders = new Headers();
const supabase = createServerSupabaseClient(Astro.request, responseHeaders);

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

// Anexos dos alertas/documentos dos equinos do dono
const { data: alertDocs } = await supabase
  .from('equine_alerts')
  .select('id, attachment_url, attachment_name, last_done_at, due_date, equine:equinos(id, name, nickname), template:alert_templates(name, category)')
  .not('attachment_url', 'is', null);

// Resenhas de equinos cadastrados por veterinários e associados ao CPF
// do dono (cadeia proprietário ↔ equino via CPF — RLS filtra)
const { data: vetDocsRaw } = await supabase
  .from('vet_equines')
  .select('id, name, resenha_url, created_at')
  .not('resenha_url', 'is', null);

const docs    = alertDocs ?? [];
const vetDocs = vetDocsRaw ?? [];

const GREEN = 'hsl(168 83% 29%)';

function fmtDate(d: string | null) {
  if (!d) return null;
  const [y, m, day] = d.slice(0, 10).split('-');
  return `${day}/${m}/${y}`;
}
---

<Layout title="Documentos — Equicore">
  <Header client:load currentPath={Astro.url.pathname} />

  <main class="w-full max-w-5xl mx-auto px-4 md:px-8 py-8 space-y-6">

    <div>
      <h1 class="text-xl font-bold tracking-tight text-foreground">Documentos</h1>
      <p class="text-sm mt-0.5 text-muted-foreground">
        Exames, laudos e anexos dos seus equinos
      </p>
    </div>

    {docs.length === 0 && vetDocs.length === 0 ? (
      <div class="rounded-2xl border bg-card p-12 flex flex-col items-center text-center gap-4"
           style="border-style: dashed;">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center"
             style={`background: hsl(168 83% 29% / 0.08);`}>
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke={GREEN} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-base text-foreground mb-1">Nenhum documento ainda</p>
          <p class="text-sm text-muted-foreground" style="max-width: 400px;">
            Os arquivos anexados nos alertas de saúde (exames, laudos, comprovantes) aparecem aqui.
          </p>
        </div>
        <a href="/dashboard/alertas"
           class="text-sm font-semibold px-4 py-2 rounded-lg text-white"
           style={`background: ${GREEN}; text-decoration: none;`}>
          Ir para Alertas
        </a>
      </div>
    ) : (
      <>
        {docs.length > 0 && (
          <div class="rounded-2xl border bg-card overflow-hidden">
            {docs.map((d: any, i: number) => (
              <div class="flex items-center gap-4 px-4 py-3"
                   style={`border-bottom: ${i < docs.length - 1 ? '1px solid hsl(var(--border))' : 'none'};`}>
                <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
                     style={`background: hsl(168 83% 29% / 0.08); color: ${GREEN};`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
                    <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-foreground truncate">
                    {d.template?.name ?? d.attachment_name ?? 'Documento'}
                  </p>
                  <p class="text-xs text-muted-foreground truncate">
                    {d.equine?.nickname || d.equine?.name || 'Equino'}
                    {d.template?.category ? ` · ${d.template.category}` : ''}
                    {fmtDate(d.last_done_at) ? ` · realizado em ${fmtDate(d.last_done_at)}` : ''}
                  </p>
                </div>
                <a href={d.attachment_url} target="_blank" rel="noopener"
                   class="text-xs font-semibold px-3 py-1.5 rounded-lg flex-shrink-0"
                   style={`background: hsl(168 83% 29% / 0.08); color: ${GREEN}; text-decoration: none;`}>
                  Abrir ↗
                </a>
              </div>
            ))}
          </div>
        )}

        {vetDocs.length > 0 && (
          <section>
            <h2 class="text-base font-bold tracking-tight text-foreground mb-3">
              Resenhas gráficas emitidas por veterinários
            </h2>
            <p class="text-xs text-muted-foreground mb-3">
              Equinos associados ao seu CPF por médicos veterinários no EquiCore.
            </p>
            <div class="rounded-2xl border bg-card overflow-hidden">
              {vetDocs.map((d: any, i: number) => (
                <div class="flex items-center gap-4 px-4 py-3"
                     style={`border-bottom: ${i < vetDocs.length - 1 ? '1px solid hsl(var(--border))' : 'none'};`}>
                  <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0"
                       style="background: hsl(221 83% 53% / 0.08); color: hsl(221 83% 53%);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-foreground truncate">Resenha — {d.name}</p>
                    <p class="text-xs text-muted-foreground">{fmtDate(d.created_at?.slice(0, 10)) ?? ''}</p>
                  </div>
                  <a href={d.resenha_url} target="_blank" rel="noopener"
                     class="text-xs font-semibold px-3 py-1.5 rounded-lg flex-shrink-0"
                     style="background: hsl(221 83% 53% / 0.08); color: hsl(221 83% 53%); text-decoration: none;">
                    Abrir ↗
                  </a>
                </div>
              ))}
            </div>
          </section>
        )}
      </>
    )}

  </main>
</Layout>

<style>
  .text-foreground        { color: hsl(var(--foreground)); }
  .text-muted-foreground  { color: hsl(var(--muted-foreground)); }
  .bg-card                { background-color: hsl(var(--card)); }
</style>
